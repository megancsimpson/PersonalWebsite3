<%- include("../partials/head") %>
<%- include("../partials/header", { activePage, pageTitle }) %>

<main>
    <section class="container hero-home">
        <div class="row align-items-center">
            <div class="col-lg-5 col-md-5 img-me hero-image">
                <img src="/images/Meganpic.jpeg" class="img-fluid rounded" alt="Portrait of Megan Simpson" loading="eager" width="500" height="600">
            </div>
            <div class="col-lg-7 col-md-7 hero-copy">
                <p class="hero-kicker">Junior Full-Stack Developer</p>
                <h2 class="hero-title">Building dependable full-stack web applications from backend logic to user experience.</h2>
                <p class="hero-intro">I combine software development training with hands-on operations leadership to deliver practical, user-centered products that are stable, maintainable, and ready for real-world use.</p>
                <div class="hero-actions">
                    <a href="/about">Learn More</a>
                    <a href="/projects">View Projects</a>
                </div>
            </div>
        </div>

        <div class="row hero-placeholder-grid">
            <div class="col-md-6">
                <div class="hero-placeholder-card">
                    <p>I design and build full-stack applications that connect clear interfaces with reliable backend functionality, focused on solving real user and business problems.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="hero-placeholder-card">
                    <p>My value is bridging technical execution with business needs: I translate requirements into clean implementation plans, collaborate effectively, and deliver consistent results in fast-moving teams.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="hero-placeholder-card">
                    <ul class="hero-skill-list">
                        <li>JavaScript full-stack development with Node.js, Express.js, MongoDB, and EJS</li>
                        <li>Building RESTful features with authentication, CRUD flows, and data validation</li>
                        <li>Clear communication and collaboration across teams</li>
                        <li>Adaptable, fast learner with strong ownership and follow-through</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-6">
                <div class="hero-placeholder-card">
                    <p>I am actively seeking a Junior Full-Stack Developer role where I can contribute to production-ready features, strengthen engineering fundamentals, and grow with a team that values quality, ownership, and continuous improvement.</p>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include("../partials/footer") %>